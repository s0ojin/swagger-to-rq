{
	"name": "swagger-to-rq",
	"version": "1.0.3",
	"description": "Convert Swagger API specs into TypeScript Interfaces and TanStack Query hooks in one command.",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.js",
	"bin": {
		"gen-rq": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "tsup src/index.ts --watch",
		"build": "tsup",
		"start": "node dist/index.js"
	},
	"keywords": [
		"swagger",
		"react-query",
		"tanstack-query",
		"typescript",
		"cli",
		"automation"
	],
	"author": "s0ojin",
	"license": "MIT",
	"dependencies": {
		"axios": "^1.7.9",
		"commander": "^14.0.3",
		"dotenv": "^17.4.2",
		"openai": "^6.38.0"
	},
	"devDependencies": {
		"@types/node": "^25.9.0",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	}
}
